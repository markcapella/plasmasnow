[Desktop Entry]
Name=plasmasnow
Comment=Wintery Drifting Scenes

Exec=plasmasnow
Type=Application

Icon=plasmasnow
StartupNotify=true
Terminal=false

Categories=Game;
Keywords=Storm; Snow;

Actions=start;nomenu;

[Desktop Action start]
Name=Start plasmasnow
Exec=plasmasnow

[Desktop Action nomenu]
Name=Start without menu
Exec=plasmasnow -hidemenu
